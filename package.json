{
  "name": "polished-japanese-training-app-ui",
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "dev:web": "COREPACK_HOME=$PWD/.corepack corepack pnpm --filter @polished/web dev",
    "dev:api": "COREPACK_HOME=$PWD/.corepack corepack pnpm --filter @polished/api start:dev",
    "dev": "concurrently \"COREPACK_HOME=$PWD/.corepack corepack pnpm dev:web\" \"COREPACK_HOME=$PWD/.corepack corepack pnpm dev:api\"",
    "build:web": "COREPACK_HOME=$PWD/.corepack corepack pnpm --filter @polished/web build",
    "build:api": "COREPACK_HOME=$PWD/.corepack corepack pnpm --filter @polished/api build",
    "build": "COREPACK_HOME=$PWD/.corepack corepack pnpm build:web && COREPACK_HOME=$PWD/.corepack corepack pnpm build:api",
    "typecheck": "COREPACK_HOME=$PWD/.corepack corepack pnpm -r typecheck",
    "lint": "COREPACK_HOME=$PWD/.corepack corepack pnpm -r lint",
    "db:generate": "PRISMA_GENERATE_SKIP_AUTOINSTALL=1 apps/api/node_modules/.bin/prisma generate --schema prisma/schema.prisma",
    "db:migrate": "PRISMA_GENERATE_SKIP_AUTOINSTALL=1 apps/api/node_modules/.bin/prisma migrate dev --schema prisma/schema.prisma",
    "db:seed": "PRISMA_GENERATE_SKIP_AUTOINSTALL=1 sh -c 'set -a; . ./.env; set +a; apps/api/node_modules/.bin/tsx prisma/seed.ts'",
    "db:studio": "PRISMA_GENERATE_SKIP_AUTOINSTALL=1 apps/api/node_modules/.bin/prisma studio --schema prisma/schema.prisma",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    }
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
