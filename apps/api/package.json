{
  "name": "@polished/api",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "start:dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"api lint not configured yet\"",
    "prisma:generate": "PRISMA_GENERATE_SKIP_AUTOINSTALL=1 prisma generate --schema ../../prisma/schema.prisma",
    "prisma:migrate:dev": "PRISMA_GENERATE_SKIP_AUTOINSTALL=1 prisma migrate dev --schema ../../prisma/schema.prisma",
    "prisma:seed": "PRISMA_GENERATE_SKIP_AUTOINSTALL=1 tsx ../../prisma/seed.ts",
    "prisma:studio": "PRISMA_GENERATE_SKIP_AUTOINSTALL=1 prisma studio --schema ../../prisma/schema.prisma"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/swagger": "^11.2.0",
    "@polished/shared": "workspace:*",
    "@prisma/client": "^6.7.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.1.6",
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.3",
    "prisma": "^6.7.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
